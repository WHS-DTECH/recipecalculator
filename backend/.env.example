# Required in all environments
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Runtime
NODE_ENV=development
PORT=4000

# Admin guard bootstrap (comma-separated emails)
ADMIN_BOOTSTRAP_EMAILS=vanessapringle@westlandhigh.school.nz
# Optional single preferred admin email (also included in bootstrap set)
PREFERRED_ADMIN_EMAIL=vanessapringle@westlandhigh.school.nz

# Database TLS options
# Set to disable only for local trusted DB usage
PGSSLMODE=require
# Set to false only if your DB provider requires non-verified cert chain
PGSSL_REJECT_UNAUTHORIZED=false

# Emergency kill switch for admin guard (not recommended)
DISABLE_ADMIN_GUARD=0

# Google Sign-In
GOOGLE_CLIENT_ID=
SESSION_SECRET=
SESSION_TTL=7d
# Use lax for standard same-site navigation. Use none only when cross-site embedding is required.
SESSION_COOKIE_SAMESITE=lax
# Optional override: true in HTTPS production, false for local HTTP development.
SESSION_COOKIE_SECURE=

# Suggestion notification email
SUGGESTION_NOTIFY_TO=vanessapringle@westlandhigh.school.nz
ADMIN_NOTIFICATION_EMAIL=vanessapringle@westlandhigh.school.nz
SUGGESTION_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Place Order pilot (Teacher)
PLACE_ORDER_PILOT_RECIPIENT=vanessapringle@westlandhigh.school.nz
PLACE_ORDER_TUESDAY_CRON=0 9 * * 2
# Accepts normal Google Forms URL (edit/viewform). Route normalizes to a shareable viewform URL.
PLACE_ORDER_GOOGLE_FORM_URL=https://docs.google.com/forms/d/1BD9mD_tGjrWcujbPfMp7JtDOuSdSpmb97_EWKt6mXyo/edit
# Accepts Google Sheet edit/share URL; route normalizes to CSV export URL.
PLACE_ORDER_GOOGLE_FORM_RESPONSES_CSV_URL=https://docs.google.com/spreadsheets/d/1dwlodt5NtO13MxB8MDktqJgP9Yvf9oLVajDFSSw-jmM/edit?usp=sharing

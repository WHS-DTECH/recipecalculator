# Required in all environments
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Runtime
NODE_ENV=development
PORT=4000

# Admin guard bootstrap (comma-separated emails)
ADMIN_BOOTSTRAP_EMAILS=vanessapringle@westlandhigh.school.nz
# Optional single preferred admin email (also included in bootstrap set)
PREFERRED_ADMIN_EMAIL=vanessapringle@westlandhigh.school.nz

# Database TLS options
# Set to disable only for local trusted DB usage
PGSSLMODE=require
# Set to false only if your DB provider requires non-verified cert chain
PGSSL_REJECT_UNAUTHORIZED=false

# Emergency kill switch for admin guard (not recommended)
DISABLE_ADMIN_GUARD=0

# Google Sign-In
GOOGLE_CLIENT_ID=
SESSION_SECRET=
SESSION_TTL=7d
SESSION_COOKIE_SAMESITE=none

# Suggestion notification email
SUGGESTION_NOTIFY_TO=vanessapringle@westlandhigh.school.nz
ADMIN_NOTIFICATION_EMAIL=vanessapringle@westlandhigh.school.nz
SUGGESTION_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
